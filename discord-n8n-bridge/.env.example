# Discord bot token — from https://discord.com/developers/applications
# (Your App → Bot → Reset Token)
DISCORD_BOT_TOKEN=your-bot-token-here

# Your n8n webhook URL.
# While building/testing, use the TEST url and click "Listen for test event" in n8n:
#   https://your-n8n-host/webhook-test/discord-agent
# Once the workflow is Activated, switch to the production url:
#   https://your-n8n-host/webhook/discord-agent
N8N_WEBHOOK_URL=https://your-n8n-host/webhook/discord-agent

# How the bot decides a message is for the agent:
#   mention (default) - only messages that @mention the bot
#   prefix            - only messages starting with PREFIX
#   all               - every message (use with CHANNEL_IDS!)
TRIGGER_MODE=mention
PREFIX=!agent

# Optional: comma-separated channel IDs the bot listens in (empty = all channels)
# Right-click a channel → Copy Channel ID (requires Developer Mode in Discord settings)
CHANNEL_IDS=
